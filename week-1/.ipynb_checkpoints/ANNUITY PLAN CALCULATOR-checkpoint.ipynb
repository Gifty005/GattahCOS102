   "source": [
    "PMT = float (input(\"Enter payment each(PMT):\"))\n",
    "r = float (input (\"Enter interest \\ rate(%):\"))/100\n",
    "t = int(input (\"Enter number of periods (t):\"))\n",
    "A = PMT* ((1 + r) ** t -1)/r\n",
    "print (\"future value of the annuity = \",A)"
   ]
